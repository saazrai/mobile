{
	"permissions": {
		"allow": ["Bash(*)"]
	},
	"enabledPlugins": {
		"frontend-design@claude-plugins-official": true
	},
	"statusLine": {
		"type": "command",
		"command": "bash /Users/saaz/.claude/statusline-command.sh"
	},
	"hooks": {
		"PostToolUse": [
			{
				"matcher": "Bash",
				"hooks": [
					{
						"type": "command",
						"if": "Bash(git push*)",
						"command": "printf '{\"systemMessage\":\"Push complete. Before opening a PR, run /security to check for auth and injection vulnerabilities.\"}'",
						"timeout": 5,
						"statusMessage": "Post-push reminder"
					}
				]
			}
		]
	}
}